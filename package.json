{
  "name": "enchanted-forest",
  "private": true,
  "version": "0.2.0",
  "description": "Rune-cadence survival grove — learn a rune, chain it, survive grove variety that tests the reading of your cadence, finish as a wiser mage.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome lint .",
    "check:format": "biome format .",
    "test": "pnpm run test:node && pnpm run test:dom",
    "test:node": "vitest run --config vitest.config.ts",
    "test:dom": "vitest run --config vitest.dom.config.ts",
    "test:browser": "vitest --config vitest.browser.config.ts --browser --run",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "framer-motion": "^12.38.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "seedrandom": "^3.0.5",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@capacitor/cli": "^8.3.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "jsdom": "^27.0.0",
    "playwright": "^1.59.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
